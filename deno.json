{
  "name": "@linus/cli",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-run=git --allow-read --allow-env src/main.ts",
    "test": "deno test --allow-run --allow-read --allow-write --allow-env tests/",
    "check": "deno check src/main.ts",
    "compile": "deno compile --allow-run=git --allow-read --allow-env --output linus src/main.ts"
  },
  "compilerOptions": {
    "strict": true
  }
}
